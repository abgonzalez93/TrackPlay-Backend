{
  "type": "module",
  "name": "@trackplay/backend",
  "author": "Antonio Bueno Gonzalez",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "rimraf dist && tsc && tsc-alias",
    "dev": "tsx --conditions=development watch --clear-screen=false -r tsconfig-paths/register src/server.ts",
    "start": "node --enable-source-maps --no-warnings dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:reset": "prisma migrate reset --force",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "barrelsby:generate": "barrelsby --config .barrelsby.json",
    "madge": "pnpm build && madge --circular dist/",
    "update": "ncu -u -e 2 && pnpm install"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@trackplay/core": "file:../trackplay-core",
    "bcrypt": "^6.0.0",
    "express": "^5.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.0",
    "barrelsby": "^2.8.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "madge": "^8.0.0",
    "prettier": "^3.6.2",
    "prisma": "^6.19.0",
    "rimraf": "^6.1.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  },
  "packageManager": "pnpm@10.20.0"
}
