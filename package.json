{
  "type": "module",
  "name": "gametrackr-backend",
  "author": "Antonio Bueno Gonzalez",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --clear-screen=false --env-file=.env -r tsconfig-paths/register src/server.ts",
    "start": "node dist/server.js",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:generate": "prisma generate",
    "prisma:reset": "prisma migrate reset --force",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "lint:fix": "eslint src --fix",
    "barrelsby:generate": "barrelsby --config .barrelsby.json",
    "madge": "madge --circular src/"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "axios": "^1.9.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "winston": "^3.17.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/compression": "^1.8.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "barrelsby": "^2.8.1",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "globals": "^16.2.0",
    "madge": "^8.0.0",
    "prettier": "^3.5.3",
    "prisma": "^6.8.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
